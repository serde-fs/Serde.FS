<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>

		<!-- Serde generator engine + MSBuild task -->
		<PackageId>Serde.FS.SourceGen</PackageId>
		<Version>$(SourceGenVersion)</Version>
		<Authors>Jordan Marr</Authors>
		<Description>
			Source generator for Serde.FS. Produces metadata and serializers for [Serde] types with full recursive strictness validation. Used by all Serde.FS backends.
		</Description>
		<PackageTags>fsharp;source-generator;serde;source-generator;fs-djinn</PackageTags>

		<!-- Packed as an analyzer package (design-time only) -->
		<IsPackable>true</IsPackable>
		<IncludeBuildOutput>false</IncludeBuildOutput>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>

		<!-- Ensures all referenced DLLs are copied into the output folder
         so they can be packed into analyzers/ -->
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>

		<!-- Local fallback version.
			 The debug pipeline supplies the real version via /p:SerdeFSVersion. -->
		<SerdeFSVersion>1.0.0-alpha.1</SerdeFSVersion>
	</PropertyGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="Serde.FS.SourceGen.Tests" />
	</ItemGroup>

	<!-- Generator engine + AST parser + code emitter + MSBuild task -->
	<ItemGroup>
		<Compile Include="SerdeMetadata.fs" />
		<Compile Include="ISerdeCodeEmitter.fs" />
		<Compile Include="DebugEmitter.fs" />
		<Compile Include="SerdeAstParser.fs" />
		<Compile Include="SerdeCodeEmitter.fs" />
		<Compile Include="RootGenericDiagnostics.fs" />
		<Compile Include="RpcApiDiscovery.fs" />
		<Compile Include="SerdeGeneratorEngine.fs" />
		<!-- Roslyn ISourceGenerator stub — excluded until F# supports source generators -->
		<!-- <Compile Include="SerdeSourceGenerator.fs" /> -->
	</ItemGroup>

	<ItemGroup>
		<!-- Serde core library (metadata + semantics) -->
		<ProjectReference Include="..\Serde.FS\Serde.FS.fsproj" />

		<!-- SourceDjinn engine (design-time only). Folded into this repo from
		     the standalone FSharp.SourceDjinn project so we can pin a single
		     FSharp.Core floor across the dependency chain (the published
		     FSharp.SourceDjinn.TypeModel package pinned 10.0.102, which made
		     Fable 5's cracker reject consumers on older runtimes). -->
		<ProjectReference Include="..\FSharp.SourceDjinn\FSharp.SourceDjinn.fsproj" PrivateAssets="all" />

		<!-- Runtime type model used by the generator. PrivateAssets="all" so
		     the TypeModel ProjectReference doesn't appear as a NuGet dep in
		     this package's nuspec — the runtime generator that actually uses
		     it lives in the published GeneratorHost tool (which bundles the
		     DLL self-contained), and the analyzer payload here is vestigial
		     until F# gains source-generator support. -->
		<ProjectReference Include="..\FSharp.SourceDjinn.TypeModel\FSharp.SourceDjinn.TypeModel.fsproj" PrivateAssets="all" />
	</ItemGroup>

	<!-- Analyzer payload: generator engine DLL + all dependencies -->
	<ItemGroup>
	  <None Include="$(OutputPath)Serde.FS.SourceGen.dll" Pack="true" PackagePath="analyzers/dotnet/fs" />

	  <None Include="$(OutputPath)Serde.FS.SourceGen.*.dll" Pack="true" PackagePath="analyzers/dotnet/fs" />
	</ItemGroup>
	<ItemGroup>
	  <!-- See Serde.FS.fsproj for the rationale on the lowered FSharp.Core floor. -->
	  <PackageReference Update="FSharp.Core" Version="8.0.100" />
	</ItemGroup>

	<!-- Roslyn Packages — needed when SerdeSourceGenerator.fs is enabled -->
	<!--
	<ItemGroup>
	  <PackageReference Include="Microsoft.CodeAnalysis.Common" Version="5.0.0" PrivateAssets="all" />
	  <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.0.0" PrivateAssets="all" />
	  <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.11.0" PrivateAssets="all" />
	</ItemGroup>
	-->


</Project>
