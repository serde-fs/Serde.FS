<Project>
  <UsingTask TaskName="FSharp.SourceDjinn.SerdeGeneratorTask"
             AssemblyFile="$(MSBuildThisFileDirectory)../analyzers/dotnet/fs/FSharp.SourceDjinn.dll" />

  <Target Name="SerdeGenerate" BeforeTargets="CoreCompile">

	<Message Text="Serde.FS.SystemTextJson.targets loaded" Importance="High" />

    <SerdeGeneratorTask SourceFiles="@(Compile)" OutputDir="$(IntermediateOutputPath)serde-generated/"
                        EmitterAssemblyPath="$(MSBuildThisFileDirectory)../analyzers/dotnet/fs/Serde.FS.SystemTextJson.dll"
                        EmitterTypeName="Serde.FS.SystemTextJson.StjCodeEmitter" />
    <!-- Add generated files to Compile, inserted after user code -->
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)serde-generated/**/*.fs"
               Condition="Exists('$(IntermediateOutputPath)serde-generated/')" />
    </ItemGroup>
  </Target>
</Project>
